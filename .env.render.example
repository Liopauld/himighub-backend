# Render environment variables for HimigHub backend
# Copy these keys into Render Web Service > Environment.

NODE_ENV=production
PORT=10000

# Database
MONGODB_URI=

# Auth
JWT_SECRET=

# CORS (optional; leave unset to allow all origins by current server fallback)
CLIENT_URL=

# Firebase Admin
FIREBASE_PROJECT_ID=
# In Render, upload firebase-service-account.json under Secret Files and set this to its path.
# Example:
FIREBASE_SERVICE_ACCOUNT_KEY=/etc/secrets/firebase-service-account.json

# PayMongo
PAYMONGO_SECRET_KEY=
PAYMONGO_SUCCESS_URL=
PAYMONGO_CANCEL_URL=

# SMTP (optional; required only if using email sending)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=

# Optional seeding script values
ADMIN_SEED_EMAIL=admin@himighub.com
ADMIN_SEED_PASSWORD=
ADMIN_SEED_NAME=HIMIGHUB Super Admin
